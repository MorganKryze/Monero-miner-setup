# Gluetun VPN configuration.
# Copy this file to .env.vpn, then uncomment ONE provider block below and fill in credentials.
# Full docs: https://github.com/qdm12/gluetun-wiki
#
# Usage: docker compose -f compose.yml -f compose.vpn.yml up -d


# ============================================================
# Mullvad (WireGuard)
# ============================================================
# Get WireGuard config from: https://mullvad.net/en/account/wireguard-config
# - WIREGUARD_PRIVATE_KEY: the [Interface] PrivateKey from the downloaded conf
# - WIREGUARD_ADDRESSES: the [Interface] Address (IPv4, usually 10.x.x.x/32)
# Mullvad's terms do not restrict mining.
#
# VPN_SERVICE_PROVIDER=mullvad
# VPN_TYPE=wireguard
# WIREGUARD_PRIVATE_KEY=
# WIREGUARD_ADDRESSES=
# Optional location filter (one or both):
# SERVER_CITIES=Zurich
# SERVER_COUNTRIES=Switzerland


# ============================================================
# ProtonVPN (WireGuard)
# ============================================================
# Get WireGuard config from: https://account.protonvpn.com/downloads (WireGuard tab).
# Generate a config for the server you want, then copy:
# - WIREGUARD_PRIVATE_KEY: [Interface] PrivateKey
# - WIREGUARD_ADDRESSES: [Interface] Address (usually 10.2.0.2/32)
# ProtonVPN's terms do not restrict mining on paid plans.
#
# VPN_SERVICE_PROVIDER=protonvpn
# VPN_TYPE=wireguard
# WIREGUARD_PRIVATE_KEY=
# WIREGUARD_ADDRESSES=
# SERVER_COUNTRIES=Switzerland


# ============================================================
# Private Internet Access (PIA) (OpenVPN)
# ============================================================
# Uses your regular PIA account login. No extra credentials needed.
# PIA allows mining.
#
# VPN_SERVICE_PROVIDER=private internet access
# VPN_TYPE=openvpn
# OPENVPN_USER=
# OPENVPN_PASSWORD=
# PIA uses regions rather than countries:
# SERVER_REGIONS=Swiss


# ============================================================
# NordVPN (OpenVPN)
# ============================================================
# WARNING: NordVPN's terms prohibit "crypto-mining" on some plans.
# Check the ToS that applies to your subscription before enabling.
#
# You must use NordVPN's SERVICE credentials, NOT your account login:
#   https://my.nordaccount.com/dashboard/nordvpn/manual-setup/
# Copy "Service username" and "Service password" from that page.
#
# VPN_SERVICE_PROVIDER=nordvpn
# VPN_TYPE=openvpn
# OPENVPN_USER=
# OPENVPN_PASSWORD=
# SERVER_COUNTRIES=Switzerland


# ============================================================
# Common tweaks (apply to every provider)
# ============================================================
# Killswitch. Keep ON so xmrig can't reach the pool if the VPN drops.
FIREWALL=on
# Container timezone (affects log timestamps).
TZ=UTC
# Log verbosity: debug | info | warning | error
LOG_LEVEL=info
