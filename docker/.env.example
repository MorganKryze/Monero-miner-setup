# Copy this file to .env and fill in your values

# Required: Your Monero wallet address
WALLET_ADDRESS=your_wallet_address_here

# Optional: Worker name
WORKER_NAME=docker_miner

# Optional: Mining pool URL
POOL_URL=gulf.moneroocean.stream

# Optional: Donation level (0-5)
DONATE_LEVEL=0

# CPU Configuration
CPU_COUNT=2.0
MAX_THREADS_PERCENT=25
FORCE_THREAD_COUNT=2

# Memory limit
MEMORY_LIMIT=1g

# Mining behavior
PAUSE_ON_BATTERY=false
PAUSE_ON_ACTIVE=false

# Optional: override the image used by docker compose.
# Default pulls the multi-arch prebuilt image from GHCR. Pin a specific tag
# (e.g. :v1.2.3, :main-abc1234) or point at a fork by changing this value.
# Leave commented to use the default.
# XMRIG_IMAGE=ghcr.io/morgankryze/monero-miner-setup:latest